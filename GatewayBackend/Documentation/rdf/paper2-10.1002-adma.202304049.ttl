# FABRICATION METHOD
##############################################################################

lova:fabrication-method/10.1002-adma.202304049/microfluidic-peg-fxiii  a  lova:FabricationMethod ;
    lova:describedIn          lova:paper/10.1002-adma.202304049 ;
    rdfs:label                "Microfluidic PEG-VS microgels with Factor XIII annealing" ;
    lova:chemistry            "Michael-type addition (thiol-ene, base-catalyzed by triethanolamine)" ;
    lova:manufacturingMethod  "Microfluidic water-in-oil emulsion (4-inlet device for 40/70 μm, 2-inlet for 130 μm)" ;
    lova:annealingChemistry   "Enzymatic (Factor XIII transglutamination between K and Q peptides)" ;
    lova:annealingConditions  "37°C, 30 min; FXIIIa 250 U/mL activated by thrombin 200 U/mL (in 200 mM Tris-HCl, 150 mM NaCl, 20 mM CaCl2)" ;
    lova:monomer              "8-arm PEG-VS (40 kDa, JenKem Technology), 5 wt%" ;
    lova:crosslinker          "MMP-degradable di-thiol peptide (Ac-GCRDGPQGIWGQDRCG-NH2, GenScript), 0.6 VS:thiol ratio" ;
    lova:surfactant           "Span 80" ;
    lova:surfactantCAS        "1338-43-8" ;
    lova:additionalReagent    "Heavy mineral oil (continuous phase)" ,
                              "Triethanolamine (0.3 M in precursor; 3% v/v in gelation oil)" ,
                              "AlexaFluor-647 C2-maleimide (10 μM, for imaging)" ;
    lova:enzyme               "Factor XIII (FXIIIa)" ;
    lova:enzymeEC             "EC 2.3.2.13" ;
    lova:enzymeRole           "Annealing (inter-particle crosslinking via K/Q peptide transglutamination)" ;
    lova:peptide              "K-peptide (Ac-FKGGERCG-NH2, GenScript, 500 μM)" ,
                              "Q-peptide (Ac-NQEQVSPLGGERCG-NH2, GenScript, 500 μM)" ,
                              "RGD (Ac-RGDSPGERCG-NH2, GenScript, 500 μM)" ;
    lova:peptideRole          "Enzymatic annealing substrate (K)" ,
                              "Enzymatic annealing substrate (Q)" ,
                              "Cell adhesion" .


