##############################################################################
# FABRICATION METHODS
##############################################################################

# HA-NB batch emulsion + tetrazine-norbornene annealing
lova:fabrication-method/10.1002-adfm.202400567/ha-nb-batch-tet  a  lova:FabricationMethod ;
    lova:describedIn          lova:paper/10.1002-adfm.202400567 ;
    rdfs:label                "Batch emulsion HA-NB microgels with tetrazine-norbornene annealing" ;
    lova:chemistry            "Thiol-norbornene photopolymerization (UV-initiated radical thiol-ene)" ;
    lova:manufacturingMethod  "Batch water-in-oil emulsion (mineral oil + 1% Span 80; size controlled by stir rate)" ;
    lova:annealingChemistry   "Tetrazine-norbornene inverse electron demand Diels-Alder click reaction" ;
    lova:annealingConditions  "HA-Tet linker mixed with HA-NB μgels; 37°C for 2 h or 4°C overnight" ;
    lova:monomer              "Hyaluronic acid norbornene (HA-NB, 3 wt%)" ;
    lova:crosslinker          "MMP-degradable peptide (Ac-GCRDGPQGIWGQDRCG-NH2, GenScript)" ;
    lova:initiator            "Irgacure 2959 (0.05 wt%)" ;
    lova:initiatorCAS         "106797-53-9" ;
    lova:surfactant           "Span 80" ;
    lova:surfactantCAS        "1338-43-8" ;
    lova:additionalReagent    "Heavy mineral oil (continuous phase)" ,
                              "HA-Tet (tetrazine-modified HA, annealing linker)" ,
                              "10 mM HEPES buffer (precursor solvent)" ;
    lova:peptide              "RGD (GCGYGRGDSPG, 1 mM, thiol-norbornene tethered)" ;
    lova:peptideRole          "Cell adhesion" .

# PEG-VS microfluidic + Factor XIII annealing
lova:fabrication-method/10.1002-adfm.202400567/microfluidic-peg-fxiii  a  lova:FabricationMethod ;
    lova:describedIn          lova:paper/10.1002-adfm.202400567 ;
    rdfs:label                "Microfluidic PEG-VS microgels with Factor XIII annealing" ;
    lova:chemistry            "Michael-type addition (thiol-ene, base-catalyzed by triethylamine)" ;
    lova:manufacturingMethod  "Microfluidic water-in-oil emulsion (4-inlet device for small, 2-inlet for large)" ;
    lova:annealingChemistry   "Enzymatic (Factor XIII transglutamination between K and Q peptides)" ;
    lova:annealingConditions  "37°C, 30 min; FXIIIa 250 U/mL activated by thrombin 200 U/mL" ;
    lova:monomer              "8-arm PEG-VS (40 kDa, JenKem Technology)" ;
    lova:crosslinker          "MMP-degradable peptide (Ac-GCRDGPQGIWGQDRCG-NH2, GenScript)" ;
    lova:surfactant           "Span 80" ;
    lova:surfactantCAS        "1338-43-8" ;
    lova:additionalReagent    "Heavy mineral oil (continuous phase)" ,
                              "Triethylamine (0.3 M in precursor; 3% v/v in gelation oil)" ;
    lova:enzyme               "Factor XIII (FXIIIa)" ;
    lova:enzymeEC             "EC 2.3.2.13" ;
    lova:enzymeRole           "Annealing (inter-particle crosslinking via K/Q peptide transglutamination)" ;
    lova:peptide              "K-peptide (Ac-FKGGERCG-NH2, GenScript, 250 μM)" ,
                              "Q-peptide (Ac-NQEQVSPLGGERCG-NH2, GenScript, 250 μM)" ,
                              "RGD (Ac-RGDSPGERCG-NH2, GenScript, 1000 μM)" ;
    lova:peptideRole          "Enzymatic annealing substrate (K)" ,
                              "Enzymatic annealing substrate (Q)" ,
                              "Cell adhesion" .


